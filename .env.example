# TypeScript 专项题库 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到 Git

# ============ Telegram Bot 配置 ============

# Bot Token - 从 @BotFather 获取
# 1. 在 Telegram 中搜索 @BotFather
# 2. 发送 /newbot 创建新 Bot，或 /mybots 查看已有 Bot
# 3. 选择 Bot 后点击 API Token 获取
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID - 你的 Telegram 用户/群组 ID
# 获取方式：在 Telegram 中搜索 @userinfobot，发送任意消息即可获取
TELEGRAM_CHAT_ID=your_chat_id_here

# ============ Vercel 部署专用（可选） ============

# Webhook 签名密钥 - 防止伪造请求
# 生成方式：openssl rand -hex 32
# 需要在设置 Webhook 时同时传入 secret_token 参数
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Raw 文件基础 URL
# 格式：https://raw.githubusercontent.com/<用户名>/<仓库名>/main/questions
GITHUB_RAW_BASE=https://raw.githubusercontent.com/YOUR_USERNAME/ts-daily-question/main/questions

# 允许的 Chat ID（与 TELEGRAM_CHAT_ID 相同）
ALLOWED_CHAT_ID=your_chat_id_here
